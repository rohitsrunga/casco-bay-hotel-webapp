			overflow: hidden;
			position: relative;
			min-height: 166px;
		}

		.testimonials-track {
			display: block;
			width: 100%;
			position: relative;
		}

		.testimonial-card {
			display: flex;
			position: absolute;
			inset: 0;
			min-height: 166px;
			padding: 1.05rem 1rem 1.15rem;
			opacity: 0;
			transform: translateX(18px);
			transition: opacity 0.35s ease, transform 0.4s ease;
			pointer-events: none;

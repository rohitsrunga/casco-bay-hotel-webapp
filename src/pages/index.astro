			background: rgba(4, 20, 36, 0.34);
			color: var(--white);
			font-size: 1.3rem;
			line-height: 1;
			padding: 0;
			cursor: pointer;
			width: 2.25rem;
			height: 2.25rem;
			z-index: 2;

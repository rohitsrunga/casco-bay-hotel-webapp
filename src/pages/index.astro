		background: var(--bg-mist);
		padding: 0.8rem;
		text-align: center;
	}

	.date-box .label {
		font-size: 0.55rem;
		text-transform: uppercase;
		letter-spacing: 0.12em;
		display: block;
		margin-bottom: 0.5rem;
		opacity: 0.8;
	}

	.date-box .day {
		font-family: var(--font-serif);
		font-size: 2.2rem;
		display: block;
		line-height: 1;
		margin-bottom: 0.2rem;
	}

	.date-box .month {
		font-size: 0.65rem;
		text-transform: uppercase;
		font-weight: 800;
		letter-spacing: 0.05em;
	}

	.booking-details-row {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 0.5rem;
	}

	.custom-input-box {
		background: var(--bg-mist);
		height: 45px;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 0 0.5rem;
	}

	.select-reset {
		background: transparent;
		border: none;
		width: 100%;
		font-family: var(--font-sans);
		font-size: 0.6rem;
		font-weight: 800;
		text-transform: uppercase;
		color: var(--navy-deep);
		cursor: pointer;
		text-align: center;
		text-align-last: center;
		outline: none;
		padding: 0;
		margin: 0;
		display: block;
		appearance: none;
		-webkit-appearance: none;
	}

	.booking-submit {
		width: 100%;
		padding: 1.4rem;
	}

	.testimonials-carousel {
		width: 100%;
		display: flex;
		flex-direction: column;
		gap: 1rem;
		align-items: center;
	}

	.testimonials-header {
		display: flex;
		justify-content: center;
	}

	.hero-eyebrow {
		color: #c7ddff;
		margin-bottom: 0;
	}

	.testimonial-carousel-shell {
		position: relative;
		width: 100%;
		max-width: 900px;
		margin: 0 auto;
	}

	.testimonial-viewport {
		width: 100%;
	}

	.testimonials-track {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 240px));
		gap: 1rem;
		justify-content: center;
	}

	.testimonial-card {
		background: linear-gradient(180deg, rgba(255, 255, 255, 0.95) 0%, rgba(242, 247, 252, 0.92) 100%);
		color: var(--navy-deep);
		padding: 1.1rem 1.15rem 1.2rem;
		border: 1px solid rgba(255, 255, 255, 0.35);
		box-shadow: 0 10px 24px rgba(4, 20, 36, 0.12);
		min-height: 170px;
		display: flex;
		flex-direction: column;
		justify-content: space-between;
		backdrop-filter: blur(10px);
	}

	.testimonial-stars {
		font-size: 0.72rem;
		letter-spacing: 0.22em;
		color: var(--accent);
		margin-bottom: 0.9rem;
	}

	.testimonial-card p {
		font-family: var(--font-serif);
		font-size: 0.92rem;
		font-style: italic;
		line-height: 1.45;
		margin-bottom: 0.8rem;
	}

	.testimonial-author {
		font-family: var(--font-sans);
		font-size: 0.62rem;
		font-weight: 800;
		letter-spacing: 0.16em;
		text-transform: uppercase;
		color: var(--text-muted);
	}

	.testimonial-nav,
	.testimonial-dots {
		display: none;
	}

	.section-header {
		display: flex;
		flex-direction: column;
		gap: 0.9rem;
		margin-bottom: 2.5rem;
		position: relative;
		z-index: 2;
	}

	.section-kicker {
		display: inline-flex;
		align-items: center;
		gap: 1rem;
		font-family: var(--font-sans);
		text-transform: uppercase;
		font-size: 0.74rem;
		font-weight: 800;
		letter-spacing: 0.18em;
	}

	.section-kicker::before {
		content: "";
		width: 34px;
		height: 1px;
		background: currentColor;
		opacity: 0.85;
	}

	.section-title {
		font-size: 3.5rem;
		line-height: 1.06;
		max-width: 760px;
	}

	.section-title strong {
		font-weight: 800;
	}

	.section-header-dark .section-kicker,
	.section-header-dark .section-title {
		color: var(--navy-deep);
	}

	.section-header-light .section-kicker,
	.section-header-light .section-title {
		color: var(--white);
	}

	.experience-block {
		display: grid;
		grid-template-columns: 1.1fr 0.9fr;
		gap: 10rem;
		align-items: center;
	}

	.experience-visual img {
		width: 100%;
		height: 750px;
		object-fit: cover;
		border: 1px solid var(--border-blue);
		box-shadow: 0 30px 60px rgba(0, 0, 0, 0.1);
	}

	.experience-content {
		padding: 2rem 0;
	}

	.experience-heading {
		font-size: 3.8rem;
		line-height: 1.1;
		margin-bottom: 2.5rem;
		color: var(--navy-deep);
	}

	.experience-heading strong {
		font-weight: 800;
		color: var(--text-main);
	}

	.experience-content p {
		font-size: 1.15rem;
		color: var(--text-muted);
		line-height: 1.8;
		margin-bottom: 2rem;
	}

	.suites-vertical-gallery {
		padding: 0 0 2rem;
		position: relative;
	}

	.rooms-intro {
		padding-top: 5.5rem;
		padding-bottom: 2rem;
		position: relative;
		z-index: 12;
	}

	.suites-split-wrapper {
		display: grid;
		grid-template-columns: 1fr 1fr;
		align-items: stretch;
		position: relative;
	}

	.suites-visual-sticky {
		position: absolute;
		top: 0;
		left: 0;
		height: 100vh;
		width: 50%;
		overflow: hidden;
		background: var(--navy-deep);
		z-index: 10;
	}

	.suites-visual-sticky.is-fixed {
		position: fixed;
		top: 0;
	}

	.suites-visual-sticky.is-bottom {
		top: auto;
		bottom: 0;
	}

	.sticky-image-container {
		position: relative;
		width: 100%;
		height: 100%;
	}

	.sticky-image-container img {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
		opacity: 0;
		transition: opacity 0.8s ease-in-out, transform 1.2s ease-out;
		transform: scale(1.05);
	}

	.sticky-image-container img.active {
		opacity: 1;
		transform: scale(1);
		z-index: 2;
	}

	.suite-image-mobile {
		display: none;
	}

	.suites-details-scroll {
		grid-column: 2;
		background: var(--navy-deep);
		color: var(--white);
		position: relative;
		z-index: 5;
	}

	.suite-content-block {
		min-height: 80vh;
		display: flex;
		align-items: center;
		padding: 10rem 10%;
		scroll-snap-align: center;
	}

	.suite-info-inner {
		max-width: 500px;
		opacity: 0.1;
		transform: translateY(40px);
		transition: all 1s cubic-bezier(0.165, 0.84, 0.44, 1);
		filter: blur(4px);
	}

	.suite-content-block.is-active .suite-info-inner {
		opacity: 1;
		transform: translateY(0);
		filter: blur(0);
	}

	.suite-info-inner .eyebrow {
		color: #60a5fa;
		margin-bottom: 1.5rem;
	}

	.suite-info-inner h2 {
		font-size: 5rem;
		line-height: 1;
		margin-bottom: 2rem;
		font-weight: 400;
	}

	.suite-specs-line {
		display: flex;
		gap: 2rem;
		font-family: var(--font-sans);
		font-size: 0.7rem;
		text-transform: uppercase;
		letter-spacing: 0.15em;
		color: #94a3b8;
		margin-bottom: 2.5rem;
		border-bottom: 1px solid rgba(255, 255, 255, 0.1);
		padding-bottom: 1.5rem;
	}

	.suite-info-inner p {
		font-size: 1.1rem;
		line-height: 1.8;
		color: #94a3b8;
		margin-bottom: 3.5rem;
	}

	.btn-primary-suites {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 1.4rem 3.5rem;
		background-color: var(--accent);
		color: var(--white) !important;
		font-family: var(--font-sans);
		text-transform: uppercase;
		letter-spacing: 0.2em;
		font-size: 0.8rem;
		font-weight: 800;
		border: none;
		cursor: pointer;
		transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
		box-shadow: 0 10px 30px rgba(37, 99, 235, 0.3);
	}

	.btn-primary-suites:hover {
		background-color: #1d4ed8;
		transform: translateY(-4px);
		box-shadow: 0 15px 40px rgba(37, 99, 235, 0.5);
	}

	.amenities-magazine-layout {
		display: grid;
		grid-template-columns: 0.8fr 1.2fr;
		gap: 8rem;
		align-items: center;
	}

	.visual-stack {
		position: relative;
	}

	.visual-main {
		height: 600px;
		background-size: cover;
		background-position: center;
		border: 1px solid var(--border-blue);
		position: relative;
		z-index: 2;
	}

	.visual-accent {
		position: absolute;
		bottom: -2rem;
		right: -2rem;
		width: 100%;
		height: 100%;
		border: 1px solid var(--accent);
		z-index: 1;
	}

	.amenities-feature-card {
		background: rgba(255, 255, 255, 0.78);
		border: 1px solid rgba(37, 99, 235, 0.12);
		box-shadow: 0 18px 50px rgba(16, 42, 67, 0.08);
		padding: 2.5rem;
		backdrop-filter: blur(8px);
	}

	.amenity-heading {
		font-size: 4rem;
		line-height: 1.08;
		margin-bottom: 1.5rem;
		color: var(--navy-deep);
	}

	.amenities-summary-grid {
		display: grid;
		grid-template-columns: minmax(0, 1.05fr) minmax(260px, 0.95fr);
		gap: 2rem;
		align-items: start;
	}

	.amenities-summary-side {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	.amenity-subtext {
		font-size: 1.1rem;
		color: var(--text-muted);
		line-height: 1.8;
		margin-bottom: 0;
	}

	.amenity-highlight-list {
		list-style: none;
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 0.85rem 1.25rem;
		margin-bottom: 0;
	}

	.amenity-highlight-list li {
		color: var(--navy-deep);
		font-weight: 600;
		padding-left: 1.25rem;
		position: relative;
	}

	.amenity-highlight-list li::before {
		content: "—";
		position: absolute;
		left: 0;
		color: var(--accent);
	}

	.amenity-detail-link {
		display: inline-flex;
		align-items: center;
		font-family: var(--font-sans);
		text-transform: uppercase;
		letter-spacing: 0.12em;
		font-size: 0.78rem;
		font-weight: 800;
		color: var(--navy-deep);
		border-bottom: 1px solid rgba(16, 42, 67, 0.25);
		padding-bottom: 0.35rem;
	}

	.amenity-detail-link:hover {
		border-bottom-color: var(--navy-deep);
	}

	.location-map-style {
		background-size: cover;
		background-position: 80% center;
		background-repeat: no-repeat;
		position: relative;
		padding: 6rem 0 8rem;
		color: var(--text-main);
		background-color: #fff;
	}

	.location-map-style .container {
		position: relative;
		z-index: 2;
	}

	.location-map-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		align-items: flex-start;
	}

	.location-map-info {
		max-width: 480px;
		background: rgba(255, 255, 255, 0.92);
		padding: 3rem;
		box-shadow: 0 15px 40px rgba(0, 0, 0, 0.05);
		backdrop-filter: blur(8px);
		border: 1px solid rgba(255, 255, 255, 0.6);
	}

	.location-hotel-visual {
		margin-bottom: 2.5rem;
		box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
	}

	.location-hotel-visual img {
		width: 100%;
		height: auto;
		display: block;
	}

	.location-text-content p {
		font-size: 0.95rem;
		line-height: 1.7;
		color: #666;
		margin-bottom: 2.5rem;
	}

	.location-heading {
		font-family: var(--font-sans);
		font-weight: 300;
		font-size: 1.8rem;
		letter-spacing: 0.1em;
		line-height: 1.3;
		margin-bottom: 2rem;
		color: #333;
	}

	.location-contact-minimal {
		margin-bottom: 2rem;
		font-size: 0.85rem;
		line-height: 1.6;
		color: #555;
	}

	.location-contact-minimal strong {
		color: var(--navy-deep);
		display: inline-block;
		width: 60px;
	}

	.location-contact-minimal p {
		margin-bottom: 0.5rem;
	}

	.location-ctas-map {
		display: flex;
		align-items: center;
		gap: 2.5rem;
	}

	.link-underlined-dark {
		font-family: var(--font-sans);
		text-transform: uppercase;
		font-size: 0.7rem;
		font-weight: 800;
		letter-spacing: 0.15em;
		color: var(--navy-deep);
		padding-bottom: 0.5rem;
		border-bottom: 1px solid rgba(16, 42, 67, 0.2);
	}

	.link-underlined-dark:hover {
		border-bottom-color: var(--navy-deep);
	}

	.location-map-pins {
		position: relative;
		height: 600px;
		width: 100%;
	}

	@media (max-width: 1024px) {
		.hero-container {
			padding: 0 2rem;
		}

		.hero-top-row,
		.experience-block,
		.amenities-magazine-layout,
		.location-map-grid {
			grid-template-columns: 1fr;
		}

		.hero-content-press,
		.experience-block {
			gap: 4rem;
		}

		.experience-visual img {
			height: 500px;
		}

		.section-title,
		.experience-heading,
		.amenity-heading {
			font-size: 2.8rem;
		}

		.rooms-intro {
			padding-bottom: 0;
		}

		.suites-split-wrapper {
			grid-template-columns: 1fr;
		}

		.suites-visual-sticky {
			display: none;
		}

		.suite-image-mobile {
			display: block;
			width: 100%;
			height: 350px;
			overflow: hidden;
		}

		.suite-image-mobile img {
			width: 100%;
			height: 100%;
			object-fit: cover;
		}

		.suite-content-block {
			height: auto;
			min-height: auto;
			padding: 0 0 6rem 0;
			background: var(--navy-deep);
			display: block;
		}

		.suite-info-inner {
			padding: 3rem 1.5rem;
			max-width: 100%;
			opacity: 1;
			transform: none;
			filter: none;
		}

		.suite-info-inner h2 {
			font-size: 3rem;
			margin-bottom: 1rem;
		}

		.suite-specs-line {
			border-bottom: none;
			padding-bottom: 0;
			margin-bottom: 2rem;
			font-style: italic;
			font-family: var(--font-serif);
			text-transform: none;
			font-size: 1.1rem;
			color: #94a3b8;
			gap: 1.5rem;
		}

		.visual-main {
			height: 400px;
		}

		.visual-accent {
			display: none;
		}

		.amenity-highlight-list {
			grid-template-columns: 1fr;
		}

		.amenities-summary-grid {
			grid-template-columns: 1fr;
			gap: 1.5rem;
		}

		.location-map-pins {
			height: 400px;
		}
	}

	@media (max-width: 768px) {
		.hero-press {
			padding: 6rem 0 3rem !important;
		}

		.hero-container {
			padding: 0 1.5rem;
			gap: 2rem;
		}

		.hero-top-row {
			gap: 2rem;
		}

		.hero-content-press {
			flex-direction: column;
			text-align: center;
			gap: 2rem;
		}

		.hero-logo-wrapper {
			display: none;
		}

		.hero-slogan-box {
			border-left: none;
			border-top: 1px solid rgba(255, 255, 255, 0.3);
			padding-left: 0;
			padding-top: 2rem;
		}

		.hero-h1 {
			letter-spacing: 0.3rem;
			font-size: 1rem;
		}

		.booking-widget-container {
			max-width: 100%;
		}

		.booking-card {
			padding: 1.2rem;
		}

		.booking-details-row {
			grid-template-columns: 1fr 1fr;
		}

		.testimonials-header {
			text-align: center;
		}

		.section-title {
			font-size: 2.3rem;
		}

		.experience-heading,
		.amenity-heading {
			font-size: 2.3rem;
		}

		.testimonial-carousel-shell {
			max-width: 360px;
			padding: 0 2.75rem;
		}

		.testimonial-viewport {
			overflow: hidden;
			position: relative;
			min-height: 166px;
		}

		.testimonials-track {
			display: block;
			width: 100%;
			position: relative;
		}

		.testimonial-card {
			display: flex;
			position: absolute;
			inset: 0;
			min-height: 166px;
			padding: 1.05rem 1rem 1.15rem;
			opacity: 0;
			transform: translateX(18px);
			transition: opacity 0.35s ease, transform 0.4s ease;
			pointer-events: none;
		}

		.testimonial-card.is-active {
			opacity: 1;
			transform: translateX(0);
			position: relative;
			pointer-events: auto;
			z-index: 2;
		}

		.testimonial-card.is-before {
			opacity: 0;
			transform: translateX(-18px);
			z-index: 1;
		}

		.testimonial-card.is-after {
			opacity: 0;
			transform: translateX(18px);
			z-index: 1;
		}

		.testimonial-card p {
			font-size: 0.9rem;
		}

		.testimonial-nav {
			display: inline-flex;
			position: absolute;
			top: 50%;
			transform: translateY(-50%);
			align-items: center;
			justify-content: center;
			border: 1px solid rgba(255, 255, 255, 0.4);
			background: rgba(4, 20, 36, 0.34);
			color: var(--white);
			font-size: 1.3rem;
			line-height: 1;
			padding: 0;
			cursor: pointer;
			width: 2.25rem;
			height: 2.25rem;
			z-index: 2;
		}

		.testimonial-nav.prev {
			left: 0;
		}

		.testimonial-nav.next {
			right: 0;
		}

		.testimonial-dot {
			width: 0.7rem;
			height: 0.7rem;
			border-radius: 999px;
			border: none;
			background: rgba(255, 255, 255, 0.35);
			cursor: pointer;
			padding: 0;

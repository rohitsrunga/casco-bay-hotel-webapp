			</div>
		</div>
	</section>

	<!-- Section 8: Good to Know -->
	<section id="good-to-know" class="good-to-know-section bg-coastal textured">
		<div class="container">
			<div class="good-to-know-layout">
				<div class="good-to-know-header">
					<span class="eyebrow">Before You Arrive</span>
					<h2 class="navy-text">Good to Know</h2>

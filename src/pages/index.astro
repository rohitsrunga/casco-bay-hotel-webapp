		font-size: 1.15rem;
		text-transform: uppercase;
		letter-spacing: 0.5rem;
		color: var(--white);
		margin: 0 0 0.5rem 0;
		font-weight: 400;
		line-height: 1.6;
	}

	.slogan-divider-line {

---
import Layout from '../layouts/Layout.astro';

const testimonials = [
	{
		quote: 'Perfect location for our Portland trip. The airport shuttle was a lifesaver and breakfast was excellent.',
		author: 'Sarah M.',
		source: 'Google Review'
	},
	{
		quote: 'Clean, modern rooms and the staff went above and beyond. Will definitely stay again when visiting Maine.',
		author: 'James T.',
		source: 'TripAdvisor'
	},
	{
		quote: 'The Park & Fly package saved us so much hassle. Great value and very convenient to the airport.',
		author: 'Linda K.',
		source: 'Choice Privileges'
	}
];
---

<Layout title="Casco Bay Hotel | South Portland, ME | Hotel Near Portland Airport" description="Casco Bay Hotel in South Portland, Maine — boutique hotel minutes from Portland International Jetport. Free airport shuttle, hot breakfast, free parking & Park & Fly packages. Book direct.">
	<section id="home" class="hero-press">
		<div id="hero-placeholder" class="hero-image-overlay" style={`background: url('${import.meta.env.BASE_URL}main-hero-bg.png') center/cover no-repeat;`}></div>

		<video id="hero-video" class="hero-video" autoplay muted loop playsinline>
			<source src={`${import.meta.env.BASE_URL}Lighthouse_Pan_Video.mp4`} type="video/mp4" />
		</video>

		<div class="hero-overlay-press"></div>

		<div class="hero-container">
			<div class="hero-top-row">
				<div class="hero-content-press">
					<div class="hero-logo-wrapper fade-in-up">
						<svg class="main-logo" viewBox="0 0 240 240" fill="none" xmlns="http://www.w3.org/2000/svg">
							<rect x="20" y="20" width="200" height="200" stroke="white" stroke-width="2" />
							<text x="50" y="150" font-family="var(--font-serif)" font-size="110" fill="white" font-weight="500">C</text>
							<text x="130" y="150" font-family="var(--font-serif)" font-size="110" fill="white" font-weight="300" opacity="0.9">B</text>
							<text x="120" y="195" text-anchor="middle" font-family="var(--font-sans)" font-size="9" fill="white" letter-spacing="0.3em" font-weight="700" text-transform="uppercase">CASCO BAY HOTEL</text>
						</svg>
					</div>
					<div class="hero-slogan-box fade-in-up">
						<h1 class="hero-h1">Classic Maine. Modern Comfort.</h1>
						<div class="slogan-divider-line"></div>
						<p class="hero-subhead">Ten minutes from the Old Port. Two minutes from the Jetport. Right in the middle of everything that makes Portland worth visiting.</p>
					</div>
				</div>

				<div class="booking-widget-container fade-in">
					<div class="booking-card">
						<div class="date-row">
							<div class="date-box" id="checkin-trigger">
								<span class="label">Check In</span>
								<input type="date" id="checkin-date" class="hidden-input" />
								<span class="day" id="checkin-day">--</span>
								<span class="month" id="checkin-month">Select</span>
							</div>
							<div class="date-box" id="checkout-trigger">
								<span class="label">Check Out</span>
								<input type="date" id="checkout-date" class="hidden-input" />
								<span class="day" id="checkout-day">--</span>
								<span class="month" id="checkout-month">Select</span>
							</div>
						</div>

						<div class="booking-details-row">
							<div class="rooms-section">
								<div class="custom-input-box">
									<select id="rooms-count" class="select-reset">
										<option value="1" selected>1 ROOM</option>
										<option value="2">2 ROOMS</option>
										<option value="3">3 ROOMS</option>
										<option value="4">4 ROOMS</option>
										<option value="5">5 ROOMS</option>
									</select>
								</div>
							</div>
							<div class="occupancy-section">
								<div class="custom-input-box">
									<select id="adults-count" class="select-reset">
										<option value="1">1 ADULT</option>
										<option value="2" selected>2 ADULTS</option>
										<option value="3">3 ADULTS</option>
										<option value="4">4 ADULTS</option>
										<option value="5">5 ADULTS</option>
										<option value="6">6 ADULTS</option>
										<option value="7">7 ADULTS</option>
										<option value="8">8 ADULTS</option>
										<option value="9">9 ADULTS</option>
										<option value="10">10 ADULTS</option>
									</select>
								</div>
							</div>
						</div>

						<button id="main-book-btn" class="btn-primary booking-submit">
							BOOK YOUR STAY
						</button>
					</div>
				</div>
			</div>

			<div class="testimonials-carousel" aria-label="Guest testimonials">
				<div class="testimonials-header">
					<span class="eyebrow hero-eyebrow">Guest Reviews</span>
					<h2>What Guests Remember</h2>
				</div>
				<div class="testimonial-carousel-shell">
					<button class="testimonial-nav prev" type="button" aria-label="Previous testimonial">‹</button>
					<div class="testimonials-track">
						{
							testimonials.map((testimonial) => (
								<article class="testimonial-card">
									<div class="testimonial-stars" aria-label="Five stars">★★★★★</div>
									<p>&ldquo;{testimonial.quote}&rdquo;</p>
									<span class="testimonial-author">{testimonial.author}, {testimonial.source}</span>
								</article>
							))
						}
					</div>
					<button class="testimonial-nav next" type="button" aria-label="Next testimonial">›</button>
				</div>
				<div class="testimonial-dots" aria-label="Testimonial pagination">
					{
						testimonials.map((_, index) => (
							<button
								type="button"
								class={`testimonial-dot${index === 0 ? ' is-active' : ''}`}
								data-index={index}
								aria-label={`Go to testimonial ${index + 1}`}
							></button>
						))
					}
				</div>
			</div>
		</div>
	</section>

	<script>
		const video = document.getElementById('hero-video') as HTMLVideoElement | null;
		const placeholder = document.getElementById('hero-placeholder') as HTMLElement | null;

		if (video && placeholder) {
			video.onplaying = () => {
				placeholder.style.opacity = '0';
				setTimeout(() => {
					placeholder.style.display = 'none';
				}, 1500);
			};
		}

		const checkinInput = document.getElementById('checkin-date') as HTMLInputElement | null;
		const checkoutInput = document.getElementById('checkout-date') as HTMLInputElement | null;
		const adultsSelect = document.getElementById('adults-count') as HTMLSelectElement | null;
		const roomsSelect = document.getElementById('rooms-count') as HTMLSelectElement | null;
		const mainBookBtn = document.getElementById('main-book-btn');

		const getLocalDateStr = (date: Date) => {
			const offset = date.getTimezoneOffset();
			const localDate = new Date(date.getTime() - offset * 60 * 1000);
			return localDate.toISOString().split('T')[0];
		};

		const today = new Date();
		const tomorrow = new Date();
		tomorrow.setDate(tomorrow.getDate() + 1);

		if (checkinInput && checkoutInput) {
			checkinInput.value = getLocalDateStr(today);
			checkoutInput.value = getLocalDateStr(tomorrow);
			updateDateDisplay();
		}

		function updateDateDisplay() {
			const months = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];

			if (checkinInput?.value) {
				const d = new Date(`${checkinInput.value}T00:00:00`);
				const checkinDay = document.getElementById('checkin-day');
				const checkinMonth = document.getElementById('checkin-month');

				if (checkinDay) checkinDay.textContent = d.getDate().toString();
				if (checkinMonth) checkinMonth.textContent = months[d.getMonth()];
			}

			if (checkoutInput?.value) {
				const d = new Date(`${checkoutInput.value}T00:00:00`);
				const checkoutDay = document.getElementById('checkout-day');
				const checkoutMonth = document.getElementById('checkout-month');

				if (checkoutDay) checkoutDay.textContent = d.getDate().toString();
				if (checkoutMonth) checkoutMonth.textContent = months[d.getMonth()];
			}
		}

		[checkinInput, checkoutInput].forEach((el) => el?.addEventListener('change', updateDateDisplay));

		function getBookingUrl() {
			const checkin = checkinInput?.value ?? '';
			const checkout = checkoutInput?.value ?? '';
			const adults = adultsSelect?.value ?? '2';
			const rooms = roomsSelect?.value ?? '1';

			return `https://www.choicehotels.com/maine/south-portland/ascend-hotels/me049?checkInDate=${checkin}&checkOutDate=${checkout}&adults=${adults}&rooms=${rooms}`;
		}

		mainBookBtn?.addEventListener('click', () => {
			window.open(getBookingUrl(), '_blank');
		});

		document.querySelectorAll('.btn-primary:not(#main-book-btn)').forEach((btn) => {
			btn.addEventListener('click', (e) => {
				if (!(btn instanceof HTMLAnchorElement) && !(btn instanceof HTMLButtonElement)) return;
				e.preventDefault();
				window.open(getBookingUrl(), '_blank');
			});
		});

		const testimonialTrack = document.querySelector('.testimonials-track') as HTMLElement | null;
		const testimonialCards = Array.from(document.querySelectorAll('.testimonial-card')) as HTMLElement[];
		const testimonialDots = Array.from(document.querySelectorAll('.testimonial-dot')) as HTMLButtonElement[];
		const prevButton = document.querySelector('.testimonial-nav.prev') as HTMLButtonElement | null;
		const nextButton = document.querySelector('.testimonial-nav.next') as HTMLButtonElement | null;
		let activeSlide = 0;
		let autoplayId: number | undefined;

		function isMobileCarousel() {
			return window.innerWidth <= 768;
		}

		function renderTestimonials(index: number) {
			if (!testimonialTrack || testimonialCards.length === 0) return;

			activeSlide = (index + testimonialCards.length) % testimonialCards.length;

			if (isMobileCarousel()) {
				testimonialTrack.style.transform = `translateX(-${activeSlide * 100}%)`;
			} else {
				testimonialTrack.style.transform = 'translateX(0)';
			}

			testimonialDots.forEach((dot, dotIndex) => {
				dot.classList.toggle('is-active', dotIndex === activeSlide);
			});
		}

		function startAutoplay() {
			window.clearInterval(autoplayId);
			if (!isMobileCarousel()) return;
			autoplayId = window.setInterval(() => renderTestimonials(activeSlide + 1), 3000);
		}

		prevButton?.addEventListener('click', () => {
			renderTestimonials(activeSlide - 1);
			startAutoplay();
		});

		nextButton?.addEventListener('click', () => {
			renderTestimonials(activeSlide + 1);
			startAutoplay();
		});

		testimonialDots.forEach((dot) => {
			dot.addEventListener('click', () => {
				const index = Number(dot.dataset.index ?? 0);
				renderTestimonials(index);
				startAutoplay();
			});
		});

		window.addEventListener('resize', () => {
			renderTestimonials(activeSlide);
			startAutoplay();
		});

		renderTestimonials(0);
		startAutoplay();
	</script>

	<section class="experience bg-coastal textured">
		<div class="container">
			<div class="experience-block">
				<div class="experience-visual">
					<img src={`${import.meta.env.BASE_URL}assets/amenities/exterior.jpg`} alt="Casco Bay Hotel exterior building in South Portland Maine" />
				</div>
				<div class="experience-content">
					<span class="eyebrow-dash">About Us</span>
					<h2 class="navy-text">Unwind in Style <span class="serif-italic">with</span> <br /> <strong>Casco Bay Hotel</strong></h2>
					<p>Casco Bay Hotel sits in South Portland, just across the bridge from the Old Port and a two-minute drive from Portland International Jetport. We renovated completely in 2022 — new rooms, new lobby, new everything — because we wanted guests to actually look forward to coming back.</p>
					<p>Whether you're here for a long weekend on the coast, a work trip to Portland, or catching an early flight out of PWM, we've built this place around making that easy.</p>
					<a href="https://www.choicehotels.com/maine/south-portland/ascend-hotels/me049" class="btn-primary">Book Now</a>
				</div>
			</div>
		</div>
	</section>

	<section id="rooms" class="suites-vertical-gallery bg-navy">
		<div class="rooms-intro container">
			<span class="eyebrow">Rooms</span>
			<h2>Stay Close to Portland, Sleep Like You Mean It</h2>
		</div>

		<div class="suites-split-wrapper">
			<div class="suites-visual-sticky">
				<div class="sticky-image-container">
					<img id="suite-img-king" src={`${import.meta.env.BASE_URL}assets/rooms/king.jpg`} alt="Deluxe King room at Casco Bay Hotel South Portland Maine" class="active" />
					<img id="suite-img-queen" src={`${import.meta.env.BASE_URL}assets/rooms/queen.jpg`} alt="Deluxe Queen room at Casco Bay Hotel South Portland Maine" />
					<img id="suite-img-double" src={`${import.meta.env.BASE_URL}assets/rooms/double.jpg`} alt="Double Suite with two beds at Casco Bay Hotel Maine" />
				</div>
			</div>

			<div class="suites-details-scroll">
				<div class="suite-content-block" data-suite="king">
					<div class="suite-image-mobile">
						<img src={`${import.meta.env.BASE_URL}assets/rooms/king.jpg`} alt="Deluxe King room at Casco Bay Hotel South Portland Maine" />
					</div>
					<div class="suite-info-inner">
						<span class="eyebrow">Signature Suite</span>
						<h2>Deluxe King</h2>
						<div class="suite-specs-line">
							<span>2 Guests</span>
							<span>1 King Bed</span>
							<span>350 SQFT</span>
						</div>
						<p>Our largest room, with a king bed, dedicated desk, and enough space to actually unpack. Good blackout shades, a Keurig, a mini fridge — the things that matter when you're in for more than one night.</p>
						<a href="https://www.choicehotels.com/maine/south-portland/ascend-hotels/me049" class="btn-primary-suites">Book Your Stay</a>
					</div>
				</div>

				<div class="suite-content-block" data-suite="queen">
					<div class="suite-image-mobile">
						<img src={`${import.meta.env.BASE_URL}assets/rooms/queen.jpg`} alt="Deluxe Queen room at Casco Bay Hotel South Portland Maine" />
					</div>
					<div class="suite-info-inner">
						<span class="eyebrow">Modern Retreat</span>
						<h2>Deluxe Queen</h2>
						<div class="suite-specs-line">
							<span>2 Guests</span>
							<span>1 Queen Bed</span>
							<span>280 SQFT</span>
						</div>
						<p>A well-sized room with a queen bed that works whether you're here for one night or four. Same amenities as our king rooms — premium WiFi, Keurig, microwave and fridge — in a layout that doesn't waste space.</p>
						<a href="https://www.choicehotels.com/maine/south-portland/ascend-hotels/me049" class="btn-primary-suites">Book Your Stay</a>
					</div>
				</div>

				<div class="suite-content-block" data-suite="double">
					<div class="suite-image-mobile">
						<img src={`${import.meta.env.BASE_URL}assets/rooms/double.jpg`} alt="Double Suite with two beds at Casco Bay Hotel Maine" />
					</div>
					<div class="suite-info-inner">
						<span class="eyebrow">Family Suite</span>
						<h2>Double Suite</h2>
						<div class="suite-specs-line">
							<span>4 Guests</span>
							<span>2 Double Beds</span>
							<span>400 SQFT</span>
						</div>
						<p>Two double beds, enough room for a family of four, and close enough to Willard Beach and the Eastern Trail that you can actually tire the kids out before bedtime. This is the room people rebook when they come back with family.</p>
						<a href="https://www.choicehotels.com/maine/south-portland/ascend-hotels/me049" class="btn-primary-suites">Book Your Stay</a>
					</div>
				</div>
			</div>
		</div>
	</section>

	<script>
		const suiteBlocks = document.querySelectorAll('.suite-content-block');
		const suiteImages = document.querySelectorAll('.sticky-image-container img');
		const stickyVisual = document.querySelector('.suites-visual-sticky') as HTMLElement | null;
		const gallerySection = document.getElementById('rooms') as HTMLElement | null;

		function handleSticky() {
			if (!stickyVisual || !gallerySection || window.innerWidth <= 1024) return;

			const rect = gallerySection.getBoundingClientRect();
			const sectionTop = rect.top;
			const sectionBottom = rect.bottom;

			const wrapper = gallerySection.querySelector('.suites-split-wrapper') as HTMLElement | null;
			if (!wrapper) return;

			const wrapperRect = wrapper.getBoundingClientRect();

			if (sectionTop <= 0 && sectionBottom >= window.innerHeight) {
				stickyVisual.classList.add('is-fixed');
				stickyVisual.classList.remove('is-bottom');
				stickyVisual.style.left = `${wrapperRect.left}px`;
				stickyVisual.style.width = `${wrapperRect.width / 2}px`;
			} else if (sectionBottom < window.innerHeight) {
				stickyVisual.classList.remove('is-fixed');
				stickyVisual.classList.add('is-bottom');
				stickyVisual.style.left = '0';
				stickyVisual.style.width = '50%';
			} else {
				stickyVisual.classList.remove('is-fixed');
				stickyVisual.classList.remove('is-bottom');
				stickyVisual.style.left = '0';
				stickyVisual.style.width = '50%';
			}
		}

		window.addEventListener('scroll', handleSticky);
		window.addEventListener('resize', handleSticky);
		handleSticky();

		const observerOptions = {
			root: null,
			threshold: 0.5,
			rootMargin: '-10% 0px -10% 0px'
		};

		const suiteObserver = new IntersectionObserver((entries) => {
			entries.forEach((entry) => {
				if (entry.isIntersecting) {
					entry.target.classList.add('is-active');
					const suiteId = entry.target.getAttribute('data-suite');
					suiteImages.forEach((img) => {
						if (img.id === `suite-img-${suiteId}`) {
							img.classList.add('active');
						} else {
							img.classList.remove('active');
						}
					});
				} else {
					entry.target.classList.remove('is-active');
				}
			});
		}, observerOptions);

		suiteBlocks.forEach((block) => suiteObserver.observe(block));
	</script>

	<section id="amenities" class="amenities-magazine bg-mist textured">
		<div class="container">
			<div class="amenities-magazine-layout">
				<div class="amenity-visual">
					<div class="visual-stack">
						<div class="visual-main" style={`background-image: url('${import.meta.env.BASE_URL}assets/amenities/food.png')`}></div>
						<div class="visual-accent"></div>
					</div>
				</div>
				<div class="amenity-content-right">
					<div class="amenity-intro-wrap">
						<span class="eyebrow">The Experience</span>
						<h2 class="navy-text">Everything You <span class="serif-italic">Actually Need</span></h2>
					</div>
					<div class="amenities-feature-card">
						<p class="amenity-subtext">Hot breakfast every morning. Free parking always. A 24-hour shuttle to and from the Jetport. Bike rentals for a spin toward the coast. EV charging on site. Fast WiFi that can handle a work call before you head into Portland.</p>
						<ul class="amenity-highlight-list">
							<li>Hot breakfast included daily</li>
							<li>Free on-site parking</li>
							<li>24-hour airport shuttle</li>
							<li>Complimentary bike rentals</li>
							<li>Electric vehicle charging</li>
							<li>Premium high-speed WiFi</li>
						</ul>
						<a href="/casco-bay-hotel-webapp/experience" class="amenity-detail-link">See all amenities & guest info →</a>
					</div>
				</div>
			</div>
		</div>
	</section>

	<section id="location" class="location-map-style" style={`background-image: url('${import.meta.env.BASE_URL}assets/location/map.jpg')`}>
		<div class="container">
			<div class="location-map-grid">
				<div class="location-map-info">
					<div class="location-hotel-visual">
						<img src={`${import.meta.env.BASE_URL}assets/location/building.jpg`} alt="Casco Bay Hotel exterior building in South Portland Maine" />
					</div>
					<div class="location-text-content">
						<h2>WHERE TO FIND US</h2>
						<p>We're on John Roberts Road in South Portland — 1.4 miles from Portland International Jetport, about 10 minutes to the Old Port depending on bridge traffic, and 5 minutes to Willard Beach if you want your feet in the ocean. Cracker Barrel and a handful of local spots are within walking distance for dinner. If you're flying in or out of PWM, we're genuinely the most convenient hotel on either side of the bridge.</p>

						<div class="location-contact-minimal">
							<p>80 John Roberts Rd, South Portland, ME 04106</p>
							<p><strong>Phone:</strong> (207) 558-4341</p>
							<p><strong>Email:</strong> frontdesk@cascobayhotel.com</p>
						</div>

						<div class="location-ctas-map">
							<a href="https://www.google.com/maps?client=safari&rls=en&oe=UTF-8&um=1&ie=UTF-8&fb=1&gl=us&sa=X&geocode=KZWazLkVmbJMMbdoIsttNxrP&daddr=80+John+Roberts+Rd,+South+Portland,+ME+04106" target="_blank" class="link-underlined-dark">Open in Maps &rarr;</a>
							<a href="https://www.choicehotels.com/maine/south-portland/ascend-hotels/me049" class="btn-primary">Book Now</a>
						</div>
					</div>
				</div>
				<div class="location-map-pins"></div>
			</div>
		</div>
	</section>
</Layout>

<style>
	.hero-press {
		position: relative;
		min-height: 100vh;
		width: 100%;
		overflow: hidden;
		display: flex;
		align-items: center;
		justify-content: center;
		color: var(--white);
		padding: 8rem 0 4rem !important;
	}

	.hero-image-overlay {
		position: absolute;
		inset: 0;
		z-index: 3;
		opacity: 0.9;
		transition: opacity 1.5s ease-in-out;
	}

	.hero-video {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
		z-index: 1;
		opacity: 0.9;
	}

	.hero-overlay-press {
		position: absolute;
		inset: 0;
		background: linear-gradient(180deg, rgba(4, 20, 36, 0.35) 0%, rgba(4, 20, 36, 0.68) 100%);
		z-index: 2;
	}

	.hero-container {
		width: 100%;
		max-width: 1400px;
		padding: 0 4rem;
		position: relative;
		z-index: 10;
		display: flex;
		flex-direction: column;
		gap: 2.5rem;
	}

	.hero-top-row {
		display: grid;
		grid-template-columns: minmax(0, 1.2fr) minmax(340px, 400px);
		align-items: center;
		gap: 3rem;
	}

	.hero-content-press {
		max-width: 680px;
		display: flex;
		align-items: center;
		gap: 3rem;
	}

	.hero-logo-wrapper {
		width: 180px;
		height: 180px;
		flex-shrink: 0;
	}

	.main-logo {
		width: 100%;
		height: 100%;
	}

	.hero-slogan-box {
		color: var(--white);
		border-left: 1px solid rgba(255, 255, 255, 0.3);
		padding-left: 3.5rem;
	}

	.hero-h1 {
		font-family: inherit;
		font-size: 1.15rem;
		text-transform: uppercase;
		letter-spacing: 0.5rem;
		color: var(--white);
		margin: 0 0 0.5rem 0;
		font-weight: 400;
		line-height: 1.6;
